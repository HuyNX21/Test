void ENGC_PrinterImpColorEngine::ans_changePrintSpeed( ushort us_Result )
{
    if( us_Result == 0 )  // OK
    {
        APIC_SystemSetting::newInstance()->setInitStab( TYPE_InitStabNonExec );
        THRF_setMachineSpeedType( uc_changeMachineType );  // ghi vào EEPROM qua BSP
